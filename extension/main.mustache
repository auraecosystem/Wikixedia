<div class="wikixedia-extension">

    <header class="wikixedia-header">
        <h1>{{name}}</h1>

        {{#version}}
        <span class="wikixedia-version">
            Version {{version}}
        </span>
        {{/version}}
    </header>

    {{#description}}
    <p class="wikixedia-description">
        {{description}}
    </p>
    {{/description}}

    {{#author}}
    <div class="wikixedia-author">
        <strong>Author:</strong> {{author}}
    </div>
    {{/author}}

    {{#license}}
    <div class="wikixedia-license">
        <strong>License:</strong> {{license}}
    </div>
    {{/license}}

    {{#features}}
    <section class="wikixedia-features">
        <h2>Features</h2>

        <ul>
            {{#.}}
            <li>{{.}}</li>
            {{/.}}
        </ul>
    </section>
    {{/features}}

    {{#commands}}
    <section class="wikixedia-commands">
        <h2>Commands</h2>

        <ul>
            {{#.}}
            <li><code>{{name}}</code> — {{description}}</li>
            {{/.}}
        </ul>
    </section>
    {{/commands}}

    {{#footer}}
    <footer class="wikixedia-footer">
        {{footer}}
    </footer>
    {{/footer}}

</div>
